{
  "name": "@agentix-e/nl2spel",
  "version": "1.3.0",
  "description": "Natural Language → SpEL Expression Generation Engine — Core",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@agentix-e/spel-ts": ">=1.1.0"
  },
  "peerDependenciesMeta": {
    "@agentix-e/spel-ts": {
      "optional": true
    }
  },
  "devDependencies": {
    "@agentix-e/spel-ts": "^1.2.2",
    "tsup": "^8.5.1",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "spel",
    "nlp",
    "expression-language",
    "spring",
    "nl2code",
    "agentix"
  ],
  "license": "MIT",
  "author": "Agentix-E",
  "repository": {
    "type": "git",
    "url": "https://github.com/AgentiX-E/nl2spel.git",
    "directory": "packages/nl2spel"
  },
  "publishConfig": {
    "access": "public"
  }
}
