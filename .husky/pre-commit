#!/usr/bin/env sh
# Husky pre-commit hook — local=CI zero drift
# Same checks as CI quality gate: typecheck + format-check + tests

echo "🔍 Running pre-commit quality gate (local=CI)..."

# TypeScript typecheck (same as CI)
echo "→ TypeScript typecheck..."
pnpm -r run typecheck
TYPECHECK_EXIT=$?
if [ $TYPECHECK_EXIT -ne 0 ]; then
  echo "❌ TypeScript typecheck failed. Fix errors before committing."
  exit 1
fi

# Format check (same as CI)
echo "→ Format check (Prettier)..."
pnpm format:check
FORMAT_EXIT=$?
if [ $FORMAT_EXIT -ne 0 ]; then
  echo "❌ Format check failed. Run 'pnpm format' to fix."
  exit 1
fi

# Run tests in packages with changed files (same as CI test job)
echo "→ Running tests (changed packages only)..."
CHANGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)
if echo "$CHANGED_FILES" | grep -q "^packages/nl2spel/"; then
  echo "  Testing @agentix-e/nl2spel..."
  pnpm --filter @agentix-e/nl2spel test || exit 1
fi
if echo "$CHANGED_FILES" | grep -q "^packages/nl2spel-openai/"; then
  echo "  Testing @agentix-e/nl2spel-openai..."
  pnpm --filter @agentix-e/nl2spel-openai test || exit 1
fi
if echo "$CHANGED_FILES" | grep -q "^packages/nl2spel-webllm/"; then
  echo "  Testing @agentix-e/nl2spel-webllm..."
  pnpm --filter @agentix-e/nl2spel-webllm test || exit 1
fi

echo "✅ Pre-commit gate passed."
