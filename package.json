{
  "name": "nl2spel-monorepo",
  "private": true,
  "description": "Natural Language → SpEL Expression Generation Engine",
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "clean": "pnpm -r run clean",
    "format": "prettier --write 'packages/**/*.ts' --config .prettierrc.cjs",
    "format:check": "prettier --check 'packages/**/*.ts' --config .prettierrc.cjs",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "husky": "^9.1.7",
    "prettier": "^3.4.2",
    "typedoc": "^0.28.20",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  }
}
